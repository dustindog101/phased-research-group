# Database
# Dev (SQLite): file:./db/dev.db
# Prod (Neon Postgres): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=file:./db/dev.db

# Prisma provider — set to "postgresql" for production (Neon)
# Edit prisma/schema.prisma datasource.provider accordingly

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-32-char-random-string

# Pay token secret for guest crypto invoice access — generate with: openssl rand -hex 32
PAY_TOKEN_SECRET=change-me-to-a-64-hex-char-string

# Crypto payments feature flag
CRYPTO_PAYMENTS_ENABLED=true

# Admin seed credentials (used only by scripts/seed.ts)
ADMIN_EMAIL=admin@phasedresearchgroup.com
ADMIN_PASSWORD=change-me-immediately

# Block explorer API keys (all optional but recommended for production)
# COINGECKO_API_KEY=
# ETHERSCAN_API_KEY=
# HELIUS_API_KEY=
# SOLANA_RPC_URL=

# Resend (email) — free 3k/mo at resend.com
# RESEND_API_KEY=
# EMAIL_FROM="Phased Research Group <noreply@phasedresearchgroup.com>"

# Vercel Blob (image storage) — free 1GB on Hobby
# BLOB_READ_WRITE_TOKEN=

# Vercel Cron secret — protects /api/cron/* endpoints
# CRON_SECRET=
